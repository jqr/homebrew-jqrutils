#!/bin/bash
set -euo pipefail

REPO="jqr/jqrutils"

if [ -n "${1:-}" ]; then
  VERSION="$1"
else
  VERSION=$(git ls-remote --tags "https://github.com/$REPO.git" \
    | awk -F/ '{print $NF}' \
    | grep '^v' \
    | sed 's/^v//' \
    | sort -V \
    | tail -1)

  if [ -z "$VERSION" ]; then
    echo "Error: no tags found in $REPO"
    exit 1
  fi

  echo "Latest tag: v$VERSION"
fi

TAG="v$VERSION"
URL="https://github.com/$REPO/archive/refs/tags/$TAG.tar.gz"

echo "Downloading $URL ..."
SHA=$(curl -sL "$URL" | shasum -a 256 | awk '{print $1}')

if [ "$SHA" = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" ]; then
  echo "Error: got empty file SHA. Does the tag exist?"
  exit 1
fi

echo "SHA256: $SHA"

cd "$(dirname "$0")/.."

for formula in *.rb; do
  sed -i '' "s|archive/refs/tags/v[^\"]*\.tar\.gz|archive/refs/tags/$TAG.tar.gz|" "$formula"
  sed -i '' "s/sha256 \"[^\"]*\"/sha256 \"$SHA\"/" "$formula"
done

echo ""
echo "Updated formula:"
grep -l "$SHA" *.rb
echo ""

read -p "Commit and push update to $TAG? [y/N] " -n 1 -r
echo ""
if [[ $REPLY =~ ^[Yy]$ ]]; then
  git commit -am "Update to $TAG" && git push
else
  echo "Aborted. Formula files have been updated but not committed."
fi
